# ---- Anthropic (direct API key) ----
# Get one at https://console.anthropic.com — this is billed pay-as-you-go,
# separate from any Claude.ai Pro/Max subscription. A daily Haiku summary
# costs cents per month.
ANTHROPIC_API_KEY=sk-ant-...

# Model used for the summary. Haiku is the cheapest and plenty for this.
# Override with claude-sonnet-4-6 for nicer prose, or claude-opus-4-8 for best quality.
SUMMARY_MODEL=claude-haiku-4-5

# ---- Target group ----
# The WhatsApp group JID, e.g. 120363012345678901@g.us
# Leave blank on first run: every inbound group message logs its JID to the
# console (LOG_UNKNOWN_GROUPS=true), so send a test message in the group,
# copy the JID printed here, then set it.
GROUP_JID=

# Print the JID of messages from groups other than GROUP_JID. Helps you
# discover the JID on first run. Set to false once GROUP_JID is configured.
LOG_UNKNOWN_GROUPS=true

# ---- Schedule ----
# Cron expression for when the summary is posted (node-cron, 5 fields).
# Default: 20:00 every day.
SUMMARY_CRON=0 20 * * *

# IANA timezone the cron runs in.
TZ=Europe/Bucharest

# ---- Storage / auth paths ----
# SQLite database file (captured messages).
DB_PATH=./data/messages.db

# Directory where Baileys persists login credentials (scan QR once).
AUTH_DIR=./auth

# How many days of messages to keep before pruning.
RETENTION_DAYS=14

# Max characters of transcript sent to the model per summary (truncates oldest
# first on very busy days to bound token cost).
MAX_TRANSCRIPT_CHARS=40000
